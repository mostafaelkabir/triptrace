{
  "manifest_version": 3,
  "name": "TripTrace",
  "version": "0.1.0",
  "description": "Scan your Gmail for flight confirmations and build your USCIS N-400 travel history.",
  "permissions": ["identity", "storage", "sidePanel"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "937802261119-5tfkmkjblbe2ok2vg49caq301b3d0ps2.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "TripTrace",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}