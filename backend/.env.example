# ── AI Provider Keys (waterfall: Claude → Gemini → Groq → OpenRouter) ─────────
# Claude is the primary provider — highest accuracy, forces JSON schema via tool_use.
# ~$0.0008/email (Haiku) with auto-escalation to Sonnet for complex emails (~$0.009).
# Set ANTHROPIC_API_KEY for best results. Other keys serve as free-tier fallbacks.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...

# ── Stripe ──────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ONETIME=price_...
STRIPE_PRICE_MONTHLY=price_...

# ── Auth ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
